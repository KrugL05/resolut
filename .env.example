# ── RESOLUTE — переменные окружения ──────────────────────────────
# Скопируйте этот файл в .env и заполните реальными значениями.
# На VPS .env лежит рядом с проектом и подхватывается PM2 (ecosystem.config.cjs).

# Порт, на котором слушает Node-сервер (Nginx проксирует /api/ сюда)
PORT=3000

# ── Telegram (обязательно — без него заявка не уйдёт) ─────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email через SMTP (опционально — если не задано, почта пропускается) ──
EMAIL_HOST=smtp.mail.ru
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=info@resolute-club.ru
